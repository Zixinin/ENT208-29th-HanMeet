# Optional override for dictionary proxy endpoint.
# If empty, frontend uses `${VITE_SUPABASE_URL}/functions/v1/dictionary-proxy`.
VITE_DICTIONARY_PROXY_URL=

# Supabase (optional for guest mode, required for cloud auth).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
